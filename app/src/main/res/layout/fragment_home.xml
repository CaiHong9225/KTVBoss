<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingTop="42dp"
        android:paddingEnd="56dp"
        android:paddingBottom="42dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="K歌打Boss"
            android:textColor="@color/text_primary"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="用声音输出伤害，把副歌唱成一场实时 Boss 战"
            android:textColor="@color/text_secondary"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Boss：噪音吞噬者"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="它会吞掉气氛、打断副歌、嘲讽跑调。你要做的，是把声场撑起来，然后在高潮段用大招直接压爆它。"
                    android:textColor="@color/text_secondary"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:text="BOSS"
                android:textColor="@android:color/white"
                android:textSize="44sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="260dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_primary_button"
                android:focusable="true"
                android:text="开始挑战"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <Button
                android:id="@+id/btnRules"
                android:layout_width="220dp"
                android:layout_height="72dp"
                android:layout_marginStart="24dp"
                android:background="@drawable/bg_secondary_button"
                android:focusable="true"
                android:text="玩法说明"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rulesContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="演示规则"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="6dp"
                android:text="1. 对着麦克风发声，音量越稳伤害越高\n2. 副歌和高潮段更容易打出连击与必杀\n3. 长时间断声会被 Boss 反击\n4. 结算页会生成 AI 评语和称号"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
